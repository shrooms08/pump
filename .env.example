# ── Shared infra ─────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── price-relay ──────────────────────────────────────────────────────────────
PRICE_SYMBOL=SOL-USDC
# mock = seeded random walk (offline-safe); flashtrade = live FlashTrade SOL oracle
PRICE_SOURCE=mock
# mock source tuning
PRICE_INTERVAL_MS=100
MOCK_START_PRICE=150
# flashtrade source (live SOL price; mainnet oracle, read-only / no auth / no key)
FLASH_V2_BASE_URL=https://flashapi.trade/v2
FLASH_SYMBOL=SOL
FLASH_POLL_MS=1000

# ── game-server ──────────────────────────────────────────────────────────────
PORT=8787
GAME_WS_URL=ws://localhost:8787/ws
POOL=devnet.1

# Ephemeral Rollup writes (start_run/delegate -> apply_event -> end_run). Off by
# default so the app runs with no chain. Turn on to record finalized RunSessions.
ER_ENABLED=false
# Server signer for the fallback signing path. Local dev: a keypair FILE PATH
# (path only — NEVER commit the key). Cloud deploy (Railway/etc.): set
# SERVER_KEYPAIR_B64 instead = base64 of the keypair JSON array; it wins over the
# path when present. Use a DEDICATED funded devnet keypair, not your upgrade authority.
KEYPAIR_PATH=~/.config/solana/id.json
# SERVER_KEYPAIR_B64=   # e.g. `base64 -i pump-server-signer.json | tr -d '\n'`
# Base layer (devnet). Public RPC works; a private devnet RPC avoids rate limits.
# Set your own URL locally — do NOT commit a URL containing an api-key.
PROVIDER_ENDPOINT=https://api.devnet.solana.com
# MagicBlock Ephemeral Rollup endpoints + validator identity (devnet).
EPHEMERAL_PROVIDER_ENDPOINT=https://devnet.magicblock.app
EPHEMERAL_WS_ENDPOINT=wss://devnet.magicblock.app
VALIDATOR=MAS1Dt9qreoRMQ14YQuhg8UTZMMzDdKhmkZMECCzk57

# ── app (Next.js) — must be NEXT_PUBLIC_ to reach the browser ─────────────────
NEXT_PUBLIC_GAME_HTTP=http://localhost:8787
# Devnet RPC the browser uses to submit the session-key authorization tx.
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# Mainnet RPC used ONLY in real mode to read SOL + USDC balances (FlashTrade real
# perp is mainnet). Public default is rate-limited — set your own (e.g. Helius
# mainnet) locally / on Vercel. Do NOT commit a URL containing an api-key.
NEXT_PUBLIC_MAINNET_RPC=https://api.mainnet-beta.solana.com
# FlashTrade V2 (opt-in real perp is MAINNET-only; price feed is read-only).
NEXT_PUBLIC_FLASH_API_BASE=https://flashapi.trade/v2
NEXT_PUBLIC_ER_RPC=https://flash.magicblock.xyz
